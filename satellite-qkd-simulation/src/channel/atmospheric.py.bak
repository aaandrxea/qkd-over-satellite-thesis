import numpy as np

from src.utils.constants import RHO_0, H_SCALE, EPS
from src.utils.io import load_yaml


# ================================
# CONFIG LOADING
# ================================

def load_atmosphere_config(config_path: str = "config/atmosphere.yaml") -> dict:
    return load_yaml(config_path)


# ================================
# DENSITÀ ATMOSFERICA
# ================================

def air_density(h: np.ndarray | float) -> np.ndarray:
    """
    Densità dell'aria (modello esponenziale)

    rho(h) = rho_0 * exp(-h / H)

    Parameters
    ----------
    h : altitude [m]

    Returns
    -------
    rho : [kg/m^3]
    """
    h = np.asarray(h)
    return RHO_0 * np.exp(-h / H_SCALE)


# ================================
# AIR MASS
# ================================

def air_mass(elevation: np.ndarray) -> np.ndarray:
    """
    Air mass semplificata

    m = 1 / sin(el)

    Protezione numerica inclusa.
    """
    elevation = np.asarray(elevation)
    elevation = np.clip(elevation, EPS, np.pi / 2)

    return 1.0 / np.sin(elevation)


# ================================
# BEER-LAMBERT SEMPLIFICATO
# ================================

def beer_lambert_transmittance(
    elevation: np.ndarray,
    tau_0: float
) -> np.ndarray:
    """
    eta = exp(-tau_0 * air_mass)
    """
    m = air_mass(elevation)
    return np.exp(-tau_0 * m)


# ================================
# MODELLO INTEGRALE (OPZIONALE)
# ================================

def integral_transmittance(
    R: np.ndarray,
    elevation: np.ndarray,
    alpha_0: float = 1e-5,
    n_steps: int = 100
) -> np.ndarray:
    """
    Versione più fisica:

    eta = exp(- ∫ alpha(h) dh )

    con:
    alpha(h) = alpha_0 * rho(h)

    """
    R = np.asarray(R)
    elevation = np.asarray(elevation)

    results = np.zeros_like(R)

    for i in range(len(R)):
        s = np.linspace(0, R[i], n_steps)

        # altezza lungo il path (approssimata)
        h = s * np.sin(elevation[i])

        rho = air_density(h)

        alpha = alpha_0 * rho

        integral = np.trapz(alpha, s)

        results[i] = np.exp(-integral)

    return results


# ================================
# INTERFACCIA PRINCIPALE
# ================================

def atmospheric_transmittance(
    elevation: np.ndarray,
    R: np.ndarray,
    config: dict | None = None
) -> np.ndarray:
    """
    Calcola la trasmittanza atmosferica.

    Parameters
    ----------
    elevation : np.ndarray [rad]
    R : np.ndarray [m]
    config : dict (opzionale)

    Returns
    -------
    eta_atm : np.ndarray
    """

    if config is None:
        config = load_atmosphere_config()

    model = config.get("model", "beer-lambert")

    if model == "beer-lambert":
        tau_0 = config.get("tau_0", 0.1)
        return beer_lambert_transmittance(elevation, tau_0)

    elif model == "integral":
        alpha_0 = config.get("alpha_0", 1e-5)
        n_steps = config.get("n_steps", 100)

        return integral_transmittance(
            R,
            elevation,
            alpha_0=alpha_0,
            n_steps=n_steps
        )

    else:
        raise ValueError(f"Unknown atmospheric model: {model}")
