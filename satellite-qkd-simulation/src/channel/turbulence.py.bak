import numpy as np

from src.utils.constants import PI, EPS
from src.utils.io import load_yaml


# ================================
# CONFIG
# ================================

def load_turbulence_config(config_path: str = "config/atmosphere.yaml") -> dict:
    cfg = load_yaml(config_path)
    return cfg.get("turbulence", {})


# ================================
# Cn^2 PROFILE
# ================================

def cn2_profile(h, v_wind, cn2_ground):
    h = np.asarray(h)

    term1 = 0.00594 * (v_wind / 27.0)*2 * (1e-5 * h)*10 * np.exp(-h / 1000.0)
    term2 = 2.7e-16 * np.exp(-h / 1500.0)
    term3 = cn2_ground * np.exp(-h / 100.0)

    return term1 + term2 + term3


# ================================
# RYTOV VARIANCE (INTEGRALE)
# ================================

def rytov_variance_integral(
    wavelength,
    R,
    elevation,
    v_wind,
    cn2_ground,
    n_steps=200
):
    k = 2.0 * PI / wavelength

    results = np.zeros_like(R)

    for i in range(len(R)):
        L = R[i]

        s = np.linspace(EPS, L, n_steps)
        h = s * np.sin(elevation[i])

        cn2 = cn2_profile(h, v_wind, cn2_ground)

        integrand = cn2 * (s ** (5.0 / 6.0))

        integral = np.trapz(integrand, s)

        results[i] = 1.23 * (k ** (7.0 / 6.0)) * integral

    return results


# ================================
# LOGNORMAL
# ================================

def lognormal_fading(sigma_R2):
    sigma = np.sqrt(np.maximum(sigma_R2, EPS))
    mu = -0.5 * sigma**2

    return np.exp(mu + sigma * np.random.normal(size=sigma.shape))


# ================================
# GAMMA-GAMMA
# ================================

def gamma_gamma_fading(sigma_R2):
    sigma_R2 = np.maximum(sigma_R2, EPS)

    alpha = (np.exp(0.49 * sigma_R2 / ((1 + 1.11 * sigma_R2*(12/5))(7/6))) - 1)*-1
    beta  = (np.exp(0.51 * sigma_R2 / ((1 + 0.69 * sigma_R2*(12/5))(5/6))) - 1)*-1

    X = np.random.gamma(alpha, 1/alpha, size=sigma_R2.shape)
    Y = np.random.gamma(beta, 1/beta, size=sigma_R2.shape)

    return X * Y


# ================================
# MAIN INTERFACE
# ================================

def turbulence_fading(
    elevation,
    R,
    wavelength,
    config=None
):
    if config is None:
        config = load_turbulence_config()

    if not config.get("enabled", True):
        return np.ones_like(R)

    model = config.get("model", "lognormal")
    profile = config.get("profile", "hufnagel-valley")

    v_wind = config.get("wind_speed", 21.0)
    cn2_ground = config.get("cn2_ground", 1.7e-14)
    n_steps = config.get("n_steps", 200)

    # Profilo (per ora uno solo)
    if profile != "hufnagel-valley":
        raise ValueError(f"Unknown turbulence profile: {profile}")

    sigma_R2 = rytov_variance_integral(
        wavelength,
        R,
        elevation,
        v_wind,
        cn2_ground,
        n_steps=n_steps
    )

    if model == "lognormal":
        return lognormal_fading(sigma_R2)

    elif model == "gamma-gamma":
        return gamma_gamma_fading(sigma_R2)

    else:
        raise ValueError(f"Unknown turbulence model: {model}")
